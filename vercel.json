{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "CACHE_TYPE": "memory",
    "STREMIO_ADDON": "true",
    "CORS_ORIGIN": "*",
    "MCP_ENABLED": "true"
  }
}