{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/dist/server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "CACHE_TYPE": "memory",
    "STREMIO_ADDON": "true",
    "CORS_ORIGIN": "*",
    "MCP_ENABLED": "true",
    "SERVER_URL": "https://stream-fetcher.vercel.app",
    "APP_URL": "https://stream-fetcher.vercel.app"
  }
}