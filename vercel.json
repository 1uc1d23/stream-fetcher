{
  "version": 2,
  "functions": {
    "src/server.ts": {
      "includeFiles": "src/providers/**"
    }
  },
  "rewrites": [
    {
      "source": "/v1/proxy",
      "destination": "/api/proxy.js"
    },
    {
      "source": "/v1/(.*)",
      "destination": "/src/server.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "CACHE_TYPE": "memory",
    "STREMIO_ADDON": "true",
    "CORS_ORIGIN": "*",
    "MCP_ENABLED": "true",
    "PUBLIC_URL": "https://stream-fetcher.vercel.app"
  }
}