{
  "version": 2,
  "builds": [
    {
      "src": "api/proxy.js",
      "use": "@vercel/node"
    },
    {
      "src": "dist/server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/v1/proxy",
      "destination": "/api/proxy.js"
    },
    {
      "source": "/(.*)",
      "destination": "/dist/server.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "CACHE_TYPE": "memory",
    "STREMIO_ADDON": "true",
    "CORS_ORIGIN": "*",
    "MCP_ENABLED": "true",
    "PUBLIC_URL": "http://localhost:3000"
  }
}